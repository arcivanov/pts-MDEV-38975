<?xml version="1.0"?>
<!--Phoronix Test Suite v10.8.4-->
<PhoronixTestSuite>
  <TestInformation>
    <Title>MariaDB BLOB</Title>
    <AppVersion>10.11</AppVersion>
    <Description>MariaDB benchmark combining stock sysbench OLTP workloads with custom tests that exercise internal temporary tables containing TEXT/BLOB/GEOMETRY columns and INFORMATION_SCHEMA queries. Designed for A/B comparison of MDEV-38975 (HEAP engine BLOB support) against the 10.11 baseline.</Description>
    <ResultScale>Queries Per Second</ResultScale>
    <Proportion>HIB</Proportion>
    <TimesToRun>3</TimesToRun>
  </TestInformation>
  <TestProfile>
    <Version>1.2.0</Version>
    <SupportedPlatforms>Linux</SupportedPlatforms>
    <SoftwareType>Benchmark</SoftwareType>
    <TestType>System</TestType>
    <License>Free</License>
    <Status>Verified</Status>
    <ExternalDependencies>build-utilities, cmake, libevent, ncurses-development, bison, flex, openssl-development, zlib-development</ExternalDependencies>
    <EnvironmentSize>6900</EnvironmentSize>
    <ProjectURL>https://mariadb.org/</ProjectURL>
    <RepositoryURL>https://github.com/MariaDB/server</RepositoryURL>
    <Maintainer>Arcadiy Ivanov</Maintainer>
    <SystemDependencies>sysbench</SystemDependencies>
  </TestProfile>
  <TestSettings>
    <Option>
      <DisplayName>Test</DisplayName>
      <Identifier>test</Identifier>
      <Menu>
        <!-- Stock sysbench OLTP tests (regression check) -->
        <Entry>
          <Name>oltp_read_write</Name>
          <Value>oltp_read_write</Value>
        </Entry>
        <Entry>
          <Name>oltp_read_only</Name>
          <Value>oltp_read_only</Value>
        </Entry>
        <Entry>
          <Name>oltp_write_only</Name>
          <Value>oltp_write_only</Value>
        </Entry>
        <Entry>
          <Name>oltp_point_select</Name>
          <Value>oltp_point_select</Value>
        </Entry>
        <Entry>
          <Name>oltp_update_non_index</Name>
          <Value>oltp_update_non_index</Value>
        </Entry>
        <Entry>
          <Name>oltp_update_index</Name>
          <Value>oltp_update_index</Value>
        </Entry>
        <!-- Custom BLOB/TEXT temp table tests -->
        <Entry>
          <Name>blob_group_by</Name>
          <Value>blob_group_by</Value>
        </Entry>
        <Entry>
          <Name>blob_distinct</Name>
          <Value>blob_distinct</Value>
        </Entry>
        <Entry>
          <Name>blob_union</Name>
          <Value>blob_union</Value>
        </Entry>
        <Entry>
          <Name>blob_subquery</Name>
          <Value>blob_subquery</Value>
        </Entry>
        <!-- INFORMATION_SCHEMA tests -->
        <Entry>
          <Name>is_columns</Name>
          <Value>is_columns</Value>
        </Entry>
        <Entry>
          <Name>is_tables_join</Name>
          <Value>is_tables_join</Value>
        </Entry>
        <!-- GEOMETRY temp table tests -->
        <Entry>
          <Name>geom_distinct</Name>
          <Value>geom_distinct</Value>
        </Entry>
        <!-- INFORMATION_SCHEMA deep tests (LONGTEXT metadata columns) -->
        <Entry>
          <!-- stored proc definitions, LONGTEXT -->
          <Name>is_routines</Name>
          <Value>is_routines</Value>
        </Entry>
        <Entry>
          <!-- view definitions, LONGTEXT -->
          <Name>is_views</Name>
          <Value>is_views</Value>
        </Entry>
        <Entry>
          <!-- trigger bodies, LONGTEXT -->
          <Name>is_triggers</Name>
          <Value>is_triggers</Value>
        </Entry>
        <Entry>
          <!-- ORM/admin tool pattern -->
          <Name>show_columns_loop</Name>
          <Value>show_columns_loop</Value>
        </Entry>
        <Entry>
          <!-- double temp table: I_S + aggregation -->
          <Name>is_group_by_complex</Name>
          <Value>is_group_by_complex</Value>
        </Entry>
        <!-- Additional temp table pathway tests -->
        <Entry>
          <Name>blob_count_distinct</Name>
          <Value>blob_count_distinct</Value>
        </Entry>
        <Entry>
          <Name>blob_group_concat</Name>
          <Value>blob_group_concat</Value>
        </Entry>
        <Entry>
          <Name>blob_window_func</Name>
          <Value>blob_window_func</Value>
        </Entry>
        <Entry>
          <Name>blob_cte</Name>
          <Value>blob_cte</Value>
        </Entry>
        <Entry>
          <!-- CTE materialization + blob read/write pressure via self-join -->
          <Name>blob_cte_materialize</Name>
          <Value>blob_cte_materialize</Value>
        </Entry>
        <Entry>
          <Name>blob_orderby_groupby</Name>
          <Value>blob_orderby_groupby</Value>
        </Entry>
        <Entry>
          <Name>blob_rollup</Name>
          <Value>blob_rollup</Value>
        </Entry>
        <Entry>
          <Name>blob_insert_select</Name>
          <Value>blob_insert_select</Value>
        </Entry>
        <!-- BLOB size case tests (HEAP continuation chain layouts) -->
        <Entry>
          <!-- 1-5 bytes, single-record zero-copy -->
          <Name>blob_case_a</Name>
          <Value>blob_case_a</Value>
        </Entry>
        <Entry>
          <!-- 1-10KB, single-run zero-copy -->
          <Name>blob_case_b</Name>
          <Value>blob_case_b</Value>
        </Entry>
        <Entry>
          <!-- 20-50KB, multi-run reassembly -->
          <Name>blob_case_c</Name>
          <Value>blob_case_c</Value>
        </Entry>
        <Entry>
          <!-- variable size, all cases -->
          <Name>blob_mixed</Name>
          <Value>blob_mixed</Value>
        </Entry>
        <!-- Explicit MEMORY temp table with BLOB: Aria on baseline, HEAP on MDEV-38975 -->
        <Entry>
          <!-- explicit MEMORY, 1-5B blobs -->
          <Name>heap_blob_case_a</Name>
          <Value>heap_blob_case_a</Value>
        </Entry>
        <Entry>
          <!-- explicit MEMORY, 1-10KB blobs -->
          <Name>heap_blob_case_b</Name>
          <Value>heap_blob_case_b</Value>
        </Entry>
        <Entry>
          <!-- explicit MEMORY, 20-50KB blobs -->
          <Name>heap_blob_case_c</Name>
          <Value>heap_blob_case_c</Value>
        </Entry>
        <Entry>
          <!-- explicit MEMORY, mixed blobs -->
          <Name>heap_blob_mixed</Name>
          <Value>heap_blob_mixed</Value>
        </Entry>
      </Menu>
    </Option>
